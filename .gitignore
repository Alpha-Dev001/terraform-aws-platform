# Terraform state — contains sensitive data, never commit
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Local config overrides
*.tfvars.local
override.tf
override.tf.json
*_override.tf

# Provider plugins — large binaries, re-downloaded by terraform init
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log
